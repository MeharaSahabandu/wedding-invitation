generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  guests    Guest[]
  createdAt DateTime @default(now())
}

model Guest {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  attending Boolean?
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([phone, userId])
}
