generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Guest {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  email       String?
  phone       String?
  attending   Boolean?
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
}
